# Copy to `.env` and fill in. The system runs FULLY OFFLINE by default — no API
# key required. Everything has sane defaults in config.py.

# --- Answer LLM (OFFLINE by default) ---
# transformers = local model in-process | openai = local vLLM/Ollama server | anthropic = cloud (opt-in)
LLM_BACKEND=transformers
LOCAL_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
LOCAL_LLM_DEVICE=cuda
# ANSWER_MAX_TOKENS=1024
# ANSWER_TEMPERATURE=0.2

# Use a local OpenAI-compatible server instead (LLM_BACKEND=openai):
# OPENAI_BASE_URL=http://localhost:8000/v1     # vLLM
# OPENAI_BASE_URL=http://localhost:11434/v1    # Ollama
# OPENAI_MODEL=Qwen/Qwen2.5-7B-Instruct

# Cloud Claude is OFF by default. Only used if LLM_BACKEND=anthropic:
# ANTHROPIC_API_KEY=sk-ant-...
# ANSWER_MODEL=claude-sonnet-4-6

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
QDRANT_COLLECTION=books

# --- Redis / queue ---
REDIS_URL=redis://localhost:6379/0

# --- Embeddings / reranker (set to "cpu" for local dev without a GPU) ---
EMBEDDING_DEVICE=cuda
RERANKER_DEVICE=cuda
# EMBEDDING_BATCH_SIZE=12

# --- OCR (qwen | surya | tesseract) ---
OCR_BACKEND=qwen
QWEN_OCR_DEVICE=cuda
# OCR_DPI=300
# OCR_LANG=ara+eng

# --- Chunking / normalization ---
# CHUNK_TARGET_TOKENS=600
# STRIP_DIACRITICS=false

LOG_LEVEL=INFO
