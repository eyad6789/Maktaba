# Copy to `.env` and fill in. The system runs FULLY OFFLINE by default — no API
# key required. Everything has sane defaults in config.py.

# --- Answer LLM (OFFLINE by default) ---
# openai = local Ollama/vLLM server (CPU-friendly, the default) |
# transformers = local model in-process (needs a GPU) | anthropic = cloud (opt-in)
LLM_BACKEND=openai
# Ollama serves quantized GGUF models — practical for a 7B answer model on CPU.
# Pull them once: `ollama pull qwen2.5:7b-instruct-q4_K_M` and `:3b-...`.
OPENAI_BASE_URL=http://localhost:11434/v1      # Ollama (vLLM: http://localhost:8000/v1)
OPENAI_MODEL=qwen2.5:7b-instruct-q4_K_M        # answers user questions
UTILITY_MODEL=qwen2.5:3b-instruct-q4_K_M       # summaries / condensation / routing
# ANSWER_MAX_TOKENS=1024
# ANSWER_TEMPERATURE=0.2

# GPU box instead? Run the model in-process:
# LLM_BACKEND=transformers
# LOCAL_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
# LOCAL_LLM_DEVICE=cuda

# Cloud Claude is OFF by default. Only used if LLM_BACKEND=anthropic:
# ANTHROPIC_API_KEY=sk-ant-...
# ANSWER_MODEL=claude-sonnet-4-6

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
QDRANT_COLLECTION=books

# --- Redis / queue ---
REDIS_URL=redis://localhost:6379/0

# --- Embeddings / reranker (CPU by default; set "cuda" on a GPU box) ---
EMBEDDING_DEVICE=cpu
RERANKER_DEVICE=cpu
# EMBEDDING_USE_FP16=false   # keep false on CPU; true only with CUDA
# RERANKER_USE_FP16=false
# EMBEDDING_BATCH_SIZE=12

# --- OCR (tesseract on CPU; qwen | surya need a GPU) ---
OCR_BACKEND=tesseract
# QWEN_OCR_DEVICE=cuda
# OCR_DPI=300
# OCR_LANG=ara+eng

# --- Chunking / normalization ---
# CHUNK_TARGET_TOKENS=600
# STRIP_DIACRITICS=false

LOG_LEVEL=INFO
